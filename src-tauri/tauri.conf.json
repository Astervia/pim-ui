{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pim",
  "version": "0.0.1",
  "identifier": "org.astervia.pim-ui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pim",
        "width": 1024,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "theme": "Dark",
        "backgroundColor": "#0a0c0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/pim-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray.png"],
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 Astervia",
    "shortDescription": "Proximity mesh UI",
    "longDescription": "Desktop + mobile UI for the pim proximity mesh daemon. Configure peers, view routing status, and inspect the mesh without leaving the terminal aesthetic.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
