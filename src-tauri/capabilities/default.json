{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — core commands + shell/log/notification/positioner plugins.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "log:default",
    "notification:default",
    "positioner:default"
  ]
}
