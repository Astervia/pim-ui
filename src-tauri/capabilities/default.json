{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — core commands + shell/log/notification/positioner plugins.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "log:default",
    "notification:default",
    "positioner:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "osascript",
          "cmd": "osascript",
          "args": [{ "validator": "\\S+" }, { "validator": "[\\s\\S]+" }],
          "sidecar": false
        },
        {
          "name": "open",
          "cmd": "open",
          "args": [{ "validator": "[\\s\\S]+" }],
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "^https://"
        },
        {
          "url": "^x-apple\\.systempreferences:"
        }
      ]
    }
  ]
}
